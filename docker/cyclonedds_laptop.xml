<?xml version="1.0" encoding="UTF-8" ?>
<!-- Developer laptop CycloneDDS config for WiFi visualization (rviz2 / ros2 CLI).
     Used inside the `humble_ws` distrobox, which shares the host network namespace.
     Pair with docker/laptop_dds_env.sh which sets RMW_IMPLEMENTATION + CYCLONEDDS_URI.

     Discovery is multicast-first: the WiFi link is DHCP, so no static peer to the robot
     is hardcoded — the robot's leased 192.168.1.x locator arrives in its SPDP multicast
     announcement. If the lab AP drops multicast, add an mDNS hostname peer (see fallback
     in docs/wiki/pages/configs/dds-config.md). -->
<CycloneDDS>
    <Domain Id="any">
        <General>
            <Interfaces>
                <!-- Laptop WiFi NIC. eno1 (wired) is down on the WiFi path; bind wlp3s0 so
                     CycloneDDS advertises the 192.168.1.x locator the robot can route to. -->
                <NetworkInterface name="wlp3s0" priority="default" multicast="default" />
            </Interfaces>
            <AllowMulticast>true</AllowMulticast>
        </General>
        <Discovery>
            <Peers>
                <Peer address="127.0.0.1"/>
            </Peers>
            <ParticipantIndex>auto</ParticipantIndex>
        </Discovery>
        <Internal>
            <!-- Host net.core.rmem_max already ≥ 4 MiB; needed to receive bursty PointCloud2. -->
            <SocketReceiveBufferSize min="4 MiB"/>
        </Internal>
    </Domain>
</CycloneDDS>
