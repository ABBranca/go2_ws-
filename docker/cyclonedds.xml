<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS>
    <Domain Id="any">
        <General>
            <Interfaces>
                <NetworkInterface name="eth0" priority="default" multicast="default" />
            </Interfaces>
        </General>
        <Internal>
            <!-- Request 4 MB socket receive buffer for high-bandwidth PointCloud2 traffic.
                 Requires: sudo sysctl -w net.core.rmem_max=4194304 on the host. -->
            <SocketReceiveBufferSize min="4194304"/>
        </Internal>
        <Discovery>
            <Peers>
                <!-- Developer laptop — explicit unicast peer to supplement multicast -->
                <Peer address="192.168.123.10"/>
            </Peers>
        </Discovery>
    </Domain>
</CycloneDDS>
