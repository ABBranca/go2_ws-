<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS>
    <Domain Id="any">
        <General>
            <Interfaces>
                <NetworkInterface name="lo"/>
                <NetworkInterface name="eth0"/>
                <!-- USB WiFi dongle (rtl8812au). In NetworkManager shared-AP mode it is
                     wlan0 = 10.42.0.1 and leases 10.42.0.x, so a laptop on the AP can discover
                     the robot. presence_required="false" keeps the stack starting when the
                     dongle is absent (wired-only sessions). -->
                <NetworkInterface name="wlan0" presence_required="false" />
            </Interfaces>
            <AllowMulticast>false</AllowMulticast>
        </General>
        <Discovery>
            <Peers>
                <Peer address="127.0.0.1"/>
                <!-- Developer laptop — the two links it can reach the robot on: -->
                <Peer address="192.168.123.222"/>   <!-- laptop over wired link (192.168.123.0/24) -->
                <Peer address="10.42.0.66"/>   <!-- laptop over wired link (192.168.123.0/24) -->


                <!-- Unicast peers make discovery independent of multicast SPDP, which the AP
                     may not forward. If the laptop's DHCP lease differs from .66, discovery
                     still completes: the laptop initiates toward the robot and the robot learns
                     the real locator from the SPDP message. mDNS hostname peer is the fallback
                     — see docs/wiki/pages/configs/dds-config.md. -->
            </Peers>
            <!-- Default è 9; il nostro stack (Nav2 + slam_toolbox + bridge + Hesai) supera questa
                 soglia. 128 = allineato al laptop (cyclonedds_laptop.xml) per discovery unicast. -->
            <MaxAutoParticipantIndex>128</MaxAutoParticipantIndex>
            <ParticipantIndex>auto</ParticipantIndex>
   </Discovery>
        <Internal>
            <!-- Socket buffers for high-bandwidth PointCloud2 traffic.
                 Requires on the host: net.core.rmem_max and net.core.wmem_max ≥ 4 MiB
                 (enforced by docker/ros_entrypoint.sh preflight). Send buffer added
                 for symmetry — the Hesai /lidar_points writer also needs
                 headroom to avoid fragment drops under burst. -->
            <SocketReceiveBufferSize min="4 MiB"/>
            <SocketSendBufferSize min="4 MiB"/>
            <!-- Writer History Cache high-water mark: bound queued samples so a slow
                 reader cannot stall the PointCloud2 writer. -->
            <Watermarks>
                <WhcHigh>4 MiB</WhcHigh>
            </Watermarks>
        </Internal>
    </Domain>
</CycloneDDS>
