# ============================================================================
# Go2 Navigation Stack — Environment Configuration
# ============================================================================
# Copy this file to .env and edit for your setup:
#   cp .env.example .env
#
# Used by: docker-compose.yml, sync_to_dog.sh, cyclonedds entrypoint
# ============================================================================

# -- Robot deployment --------------------------------------------------------
ROBOT_IP=192.168.123.18
ROBOT_USER=unitree
ROBOT_WORKSPACE=/home/unitree/go2_ws

# -- ROS 2 DDS --------------------------------------------------------------
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# -- CycloneDDS networking --------------------------------------------------
# Network interface inside the container (eth0 on Orin, may differ elsewhere)
CYCLONEDDS_INTERFACE=eth0

# Optional: explicit unicast peer for cross-host DDS discovery.
# Leave empty to rely on multicast only.
CYCLONEDDS_PEER=
